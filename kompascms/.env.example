# KompasCMS — переменные окружения. Скопируй в .env.local

# Строка подключения к Postgres
DATABASE_URL=postgres://user:password@host:5432/dbname

# Секрет для подписи JWT — сгенерируй случайную длинную строку:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=ЗАМЕНИ_НА_СЛУЧАЙНУЮ_СТРОКУ

# SSL для Postgres: false для локальной БД, по умолчанию включён
PGSSL=true
